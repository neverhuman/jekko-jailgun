# Copy real values to ~/.jekko/jailgun/browser-profiles.env. Do not commit the
# populated file; browser profiles are durable credentials.

JAILGUN_GLOBAL_CONFIG=$HOME/.jailgun/config.json
JAILGUN_BROWSER_PROFILES=$HOME/.jailgun/browser-profiles.json

JEKKO_JAILGUN_ACCOUNT_A=chatgpt-a
JEKKO_JAILGUN_ACCOUNT_B=chatgpt-b
JEKKO_JAILGUN_ACCOUNT_IDS=chatgpt-a,chatgpt-b

JAILGUN_CDP_HOST=127.0.0.1
JAILGUN_CDP_PORT=9224
JAILGUN_CDP_URL=http://127.0.0.1:9224
JEKKO_JAILGUN_CDP_PORT_POOL=9224,9225

JAILGUN_CHROME_PROFILE_DIR=$HOME/.jailgun/profiles/chatgpt-a
JAILGUN_CHROME_STATE_DIR=$HOME/.jailgun/browser-state/chatgpt-a
JAILGUN_DOWNLOADS_DIR=$HOME/.jailgun/downloads/chatgpt-a
JAILGUN_CHROME_PROFILE_DIRS=$HOME/.jailgun/profiles/chatgpt-a,$HOME/.jailgun/profiles/chatgpt-b
JEKKO_JAILGUN_PROFILE_POOL=$HOME/.jailgun/profiles/chatgpt-a,$HOME/.jailgun/profiles/chatgpt-b
JEKKO_JAILGUN_PRIMARY_PROFILE_DIR=$HOME/.jailgun/profiles/chatgpt-a
JEKKO_JAILGUN_PRIMARY_STATE_DIR=$HOME/.jailgun/browser-state/chatgpt-a
JEKKO_JAILGUN_PRIMARY_DOWNLOADS_DIR=$HOME/.jailgun/downloads/chatgpt-a

JAILGUN_CHROME_EXECUTABLE=/usr/bin/google-chrome
