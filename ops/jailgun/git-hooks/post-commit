#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

token_file="${JAILGUN_TELEGRAM_TOKEN_FILE:-telegram/token.env}"
if [[ ! -f "$token_file" ]]; then
  exit 0
fi
chat_id_cache="${JAILGUN_TELEGRAM_CHAT_ID_CACHE:-telegram/chat_id.cache}"

cargo run -q -p jailgun-cli -- notify-commit \
  --token-file "$token_file" \
  --chat-id-cache "$chat_id_cache" \
  --repo "$repo_root" \
  --revision HEAD >/dev/null
