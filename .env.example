JAILGUN_CONFIG=config/jailgun.local.toml
JAILGUN_CHROME_PROFILE_DIR=/path/to/dedicated/chrome-profile
JAILGUN_CHROME_STATE_DIR=/path/to/browser-state
JAILGUN_ARTIFACTS_DIR=artifacts
JAILGUN_REMOTE_HOST=example-host
JAILGUN_REMOTE_DIR=/srv/example-project
JAILGUN_REMOTE_COMMAND=
JAILGUN_REMOTE_CLEANUP_POLICY=preserve-reset
JAILGUN_SOURCE_REPO_URL=https://github.com/example-org/example-project.git
